# Computer — root environment template
# Copy to .env and fill in values (or run ./bootstrap.sh which generates this automatically)
# NEVER commit .env files

# Database
POSTGRES_PASSWORD=REPLACE_ME_POSTGRES_PASSWORD
POSTGRES_USER=computer
POSTGRES_DB=computer_dev
DATABASE_URL=postgresql+asyncpg://computer:REPLACE_ME_POSTGRES_PASSWORD@localhost:5432/computer_dev

# Redis
REDIS_PASSWORD=REPLACE_ME_REDIS_PASSWORD
REDIS_URL=redis://:REPLACE_ME_REDIS_PASSWORD@localhost:6379/0

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_HEALTHCHECK_PASSWORD=REPLACE_ME_MQTT_PASSWORD
MQTT_ORCHESTRATOR_PASSWORD=REPLACE_ME_MQTT_PASSWORD
MQTT_EVENT_INGEST_PASSWORD=REPLACE_ME_MQTT_PASSWORD
MQTT_GREENHOUSE_CONTROL_PASSWORD=REPLACE_ME_MQTT_PASSWORD
MQTT_HYDRO_CONTROL_PASSWORD=REPLACE_ME_MQTT_PASSWORD
MQTT_HA_ADAPTER_PASSWORD=REPLACE_ME_MQTT_PASSWORD
MQTT_FRIGATE_ADAPTER_PASSWORD=REPLACE_ME_MQTT_PASSWORD
MQTT_ENERGY_ENGINE_PASSWORD=REPLACE_ME_MQTT_PASSWORD
MQTT_ROVER_CONTROL_PASSWORD=REPLACE_ME_MQTT_PASSWORD
MQTT_DRONE_CONTROL_PASSWORD=REPLACE_ME_MQTT_PASSWORD

# Auth
JWT_SECRET=REPLACE_ME_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Service URLs (for local dev; default values match docker-compose)
ORCHESTRATOR_URL=http://localhost:8002
DIGITAL_TWIN_URL=http://localhost:8001
CONTROL_API_URL=http://localhost:8000
EVENT_INGEST_URL=http://localhost:8003
ASSISTANT_API_URL=http://localhost:8014
MODEL_ROUTER_URL=http://localhost:8013
IDENTITY_SERVICE_URL=http://localhost:8010
MEMORY_SERVICE_URL=http://localhost:8011
CONTEXT_ROUTER_URL=http://localhost:8012

# Home Assistant (if using ha-adapter)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Frigate (if using frigate-adapter)
FRIGATE_URL=http://frigate.local:5000

# Ollama (for assistant/model-router; operator must start separately)
OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:7b

# Site
SITE_ID=spokane-01
SITE_NAME=Spokane Homestead
